# Google OAuth (for zkLogin)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/zklogin/callback

# Secrets
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
ZKLOGIN_SALT_SECRET=your-zklogin-salt-secret-min-32-chars
ENCRYPTION_MASTER_KEY=your-32-byte-hex-encryption-key-here

# Pinata IPFS
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# Platform Config
PLATFORM_FEE_PERCENTAGE=10
VIDEO_REVENUE_CAP_USD=20
SUI_USD_FALLBACK=1.5
ETH_USD_FALLBACK=3000

# Dev only
ALLOW_MOCK_PAYMENT=true

# Admin — Google email that gets platform admin privileges
ADMIN_EMAIL=
